<odoo>
    <data>
        <record model="ir.ui.view" id="skill_plan_view">
            <field name="name">My Skill Plan</field>
            <field name="model">skill_development.initial_plan_wizard</field>
            <field name="arch" type="xml">
                <form string="Skill Plan">

                                    <!--form content-->
                    <sheet>
                        <group string="Create your own success story, one step at a time!"
                               style="color: #5b84d7; text-transform: none;">
                            <div style="text-align: center; margin-bottom: 20px;">
                                <h2 style="font-size: 24px; font-weight: bold;">
                                    <field name="skill_name" readonly="1"/>
                                </h2>
                            </div>
                        </group>

                        <group>
                            <field name="motivation" string="My Motivation: "/>
                            <field name="endpoint" string="Preferred Endpoint: "/>
                            <field name="msg_2self" string="Message to My Self: "/>
                        </group>
                    </sheet>

<!--                form buttons-->
                    <footer>
                        <button name="button_create_plan"
                                string="Create Learning Plan"
                                type="object"
                                class="btn-primary"/>

                        <button string="Cancel"
                                class="btn-secondary"
                                special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>