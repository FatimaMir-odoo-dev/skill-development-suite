<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="lesson_bank_form_view_popup">
            <field name="name">My Reflection</field>
            <field name="model">skill_development.goal_lesson_bank_wizard</field>
            <field name="arch" type="xml">
                <form string="Reflection">

                                    <!--form content-->
                    <sheet>
                        <group string="Reflect Upon Your Journey So Far"
                               style="color: #5b84d7; text-transform: none;">
                            <div style="text-align: center; margin-bottom: 20px;">
                                <h2 style="font-size: 24px; font-weight: bold;">
                                    <field name="goal_id" readonly="1" context="{'show_view': False}"/>
                                </h2>
                            </div>
                        </group>

                        <div>
                            <field name="learner_plan_record_ids" readonly="1" context="{'show_view': False}"/>
                            <field name="lesson_title"/>
                        </div>
                        <div>
                                <field name="lesson_worked" placeholder="Write 'None' if Nothing Comes to Mind."
                                string="What worked well for you this time?"/>

                                <field name="lesson_change" placeholder="Write 'None' if Nothing Comes to Mind."
                                       string="What Would you Do Differently Next Time?"/>

                                <field name="lesson_learned" placeholder="Write 'None' if Nothing Comes to Mind."
                                       string="What's Something New You've Learned?"/>

                                <field name="extra_thoughts"
                                       placeholder="Optional"
                                       string="Any other thoughts you’d like to share? (Optional)"/>
                        </div>
                    </sheet>

<!--                form buttons-->
                    <footer>
                        <button name="button_save_lesson"
                                string="Save Lesson"
                                type="object"
                                class="btn-primary"/>

                        <button string="Cancel"
                                class="btn-secondary"
                                special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>