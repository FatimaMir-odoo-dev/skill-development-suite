<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="skill_plan_view">
            <field name="name">My Reflection</field>
            <field name="model">skill_development.goal_lesson_bank_wizard</field>
            <field name="arch" type="xml">
                <form string="Reflection">

                                    <!--form content-->
                    <sheet>
                        <group string="Reflect Upon Your Journey So Far"
                               style="color: #5b84d7; text-transform: none;">
                            <div style="text-align: center; margin-bottom: 20px;">
                                <h2 style="font-size: 24px; font-weight: bold;">
                                    <field name="goal_id" readonly="1"/>
                                </h2>
                            </div>
                        </group>

                        <group>
                            <field name="lesson_title"/>
                            <field name="lesson" string="I Learned: " widget="html"/>
                        </group>
                    </sheet>

<!--                form buttons-->
                    <footer>
                        <button name="button_save_lesson"
                                string="Create Learning Plan"
                                type="object"
                                class="btn-primary"/>

                        <button string="Cancel"
                                class="btn-secondary"
                                special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>