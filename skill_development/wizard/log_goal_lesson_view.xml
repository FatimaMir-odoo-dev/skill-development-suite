<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="log_goal_lesson_wizard_view_form" model="ir.ui.view">
            <field name="name">log.goal.lesson.wizard.view.form</field>
            <field name="model">skill_development.log_goal_lesson</field>
            <field name="arch" type="xml">
                <form string="Reflection">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="lesson_title" placeholder="Lesson Title..."/>
                            </h1>
                        </div>
                        <group string="Add to your learning journey: Answer these three reflection questions!!"
                               style="color: #5b84d7; text-transform: none;">
                            <group name="top_info">
                                <group string="Goal &amp; Skill">
                                    <field name="goal_id" options="{'no_open': True, 'no_create': True}"/>
                                    <field name="skill_id" widget="many2many_badge"
                                           options="{'no_open': True, 'no_create': True}"/>
                                </group>
                                <group string="Priority &amp; Tags" name="priority_tags">
                                    <field name="priority" widget="priority"/>
                                    <field name="tag_ids" widget="many2many_tags"
                                           options="{'color_field': 'color', 'no_open': True, 'no_create': True}"/>
                                </group>
                            </group>

                            <notebook>
                                <page string="Learning Insights">
                                    <h4>What worked?</h4>
                                    <field name="lesson_worked"
                                           placeholder="Write 'None' if nothing comes to mind."
                                           nolabel="1"
                                           class="o_field_text_block"/>
                                    <h4>What would you change next time?</h4>
                                    <field name="lesson_change"
                                           placeholder="Write 'None' if nothing comes to mind."
                                           nolabel="1"
                                           class="o_field_text_block"/>
                                    <h4>What's something new you've learned?</h4>
                                    <field name="lesson_learned"
                                           placeholder="Write 'None' if nothing comes to mind."
                                           nolabel="1"
                                           class="o_field_text_block"/>
                                </page>
                                <page string="Additional Thoughts" name="extra">
                                    <field name="extra_thoughts"
                                           placeholder="Optional notes..."
                                           nolabel="1"
                                           class="o_field_text_block"/>
                                </page>
                            </notebook>
                        </group>
                        <footer>
                            <button name="button_save_lesson"
                                    string="Save Lesson"
                                    type="object"
                                    class="btn-primary"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>


    </data>
</odoo>