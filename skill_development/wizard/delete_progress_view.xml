<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_confirm_delete_skill_wizard" model="ir.ui.view">
            <field name="name">confirm.delete.skill.wizard</field>
            <field name="model">skill_development.delete_progress</field>
            <field name="arch" type="xml">
                <form string="Confirm Deletion">
                    <p>Are you sure you want to delete this skill?</p>
                    <p>This action is <strong>permanent</strong> and will remove all associated data (goals, tasks,
                        lessons learned).
                    </p>
                    <p>Consider <em>archiving</em> instead to preserve your data.
                    </p>
                    <footer>
                        <button string="Delete Permanently" type="object" name="confirm_delete" class="btn btn-danger"/>

                        <button string="Cancel" special="cancel" class="btn btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>