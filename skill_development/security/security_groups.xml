<odoo>
    <record id="initial_plan_record_rule_user_own_and_skills" model="ir.rule">
        <field name="name">User Own and Skills</field>
        <field name="model_id" ref="skill_development.model_skill_development_initial_plan_record"/>
         <field name="groups" eval="[(4, ref('skill_development.skill_development_group_general_admin')),
                                (4, ref('skill_development.skill_development_group_learner'))]"/>
        <field name="domain_force">[('plan_owner_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>