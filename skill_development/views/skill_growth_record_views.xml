<odoo>
    <data>

        <record id="skill_growth_view_tree" model="ir.ui.view">
            <field name="name">My Skill Growth</field>
            <field name="model">skill_development.growth_tracker</field>
            <field name="arch" type="xml">
                <tree string="My Skill Growth" create="false">
                    <field name="is_acquired" invisible="1"/>
                    <field name="sequence" widget="handle"/>
                    <field name="skill_name"/>
                    <field name="title" widget="badge"/>
                    <field name="motivation_short"/>
                    <field name="endpoint" widget="remaining_days"/>
                    <button name="goals_button" type="object" string="Goals" icon="fa-arrow-right"/>
                    <field name="skill_status" widget="badge" decoration-success="is_acquired"/>
                    <button name="action_archive_plan" type="object" icon="fa-bookmark"/>
                    <button name="action_delete_plan" type="object" icon="fa-trash"/>
                </tree>
            </field>
        </record>

        <record id="skill_growth_view_form" model="ir.ui.view">
            <field name="name">My Skill Growth</field>
            <field name="model">skill_development.growth_tracker</field>
            <field name="arch" type="xml">
                <form create="false">
                    <sheet>
                        <field name="is_acquired" invisible="1"/>
                        <div attrs="{'invisible': [('is_acquired', '!=', True)]}"
     style="
        position: absolute;
        top: 0;
        right: 0;
        width: 500px;
        height: 500px;
        overflow: hidden;
        pointer-events: none;
        z-index: 10;">

    <div style="
        position: absolute;
        top: 90px;
        right: -80px;
        width: 400px;
        background: linear-gradient(to right,
            rgba(39, 174, 96, 0.1) 0%,
            rgba(39, 174, 96, 1) 35%,
            rgba(39, 174, 96, 1) 65%,
            rgba(39, 174, 96, 0.1) 100%);
        color: white;
        text-align: center;
        transform: rotate(45deg);
        font-weight: bold;
        font-size: 16px;
        padding: 10px 0;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);">
        Skill Acquired
    </div>
</div>

                        <div class="oe_button_box" name="button_box" t-att-style="'position: relative;'">
                            <!-- Title as Badge -->
                            <h1 t-att-style="'position: absolute; background-color: #2980b9; color: white; padding: 4px 10px; border-radius: 0 0 12px 0; font-size: 25px; font-weight: bold;'">
                                <field name="title"/>
                            </h1>

                            <!-- Button Box with the Goal Button -->
                            <button name="goals_button"
                                    string="Goals"
                                    type="object"
                                    icon="fa-bullseye"
                                    class="oe_stat_button"
                                    t-att-style="'font-weight: bold; font-size: 14px;'"
                                    help="Transform your learning aspirations into actionable steps by creating a new goal. This helps you focus your efforts and measure your progress.">
                                <field name="goal_count" widget="statinfo"/>
                            </button>
                        </div>

                        <group col="1">
                            <group>
                                <div style="display: flex; justify-content: flex-end; width: 100%; margin-bottom: 8px;">
                                    <button name="popup_help_button"
                                            type="object"
                                            icon="fa-question"
                                            help="Find helpful information, tips, and explanations about skill progress and calculations."
                                            class="btn btn-info btn-sm"
                                            style="font-weight: bold; font-size: 14px;">
                                    </button>
                                </div>
                                <group style="width: 66%; display: inline-block; vertical-align: top;">
                                    <field name="skill_name" required="1"/>
                                    <field name="motivation"
                                           attrs="{'readonly': [('is_acquired', '=', True)]}"/>
                                    <field name="endpoint"
                                           attrs="{'readonly': [('is_acquired', '=', True)]}"/>
                                    <field name="msg_2self"
                                           attrs="{'readonly': [('is_acquired', '=', True)]}"/>
                                </group>

                                <group style="width: 33%; display: inline-block; vertical-align: top;" col="1">
                                    <field name="maximum_progress" invisible="1"/>
                                    <field name="overall_progress"
                                           style="font-size: 30px; font-weight: bold"
                                           widget="gauge"
                                           options="{'max_field': 'maximum_progress'}"
                                           nolabel="1"/>
                                </group>
                            </group>

                        </group>
                        <group string="Progress Categories" col="3">
                            <!--                            <div class="row">-->
                            <group>
                                <field name="progress_knowledge" widget="percentpie"/>
                            </group>
                            <group>
                                <field name="progress_practice" widget="percentpie"/>
                            </group>
                            <group>
                                <field name="progress_contribute" widget="percentpie"/>
                            </group>
                            <!--                            </div>-->
                        </group>
                        <notebook>
                            <page string="Scribbles">
                                <group>
                                    <field name="scribble_note"
                                           type="html"
                                           class="o_field_text_block"
                                           style="height: 200px;"
                                           placeholder="Use this to quickly note your ideas before you lose them..."
                                           colspan="2"
                                           attrs="{'readonly': [('is_acquired', '=', True)]}"/>
                                </group>
                                <div style="display: flex; justify-content: flex-end; margin-top: 40px;">
                                    <button name="skill_acquired_button"
                                            string="Mark Skill As Acquired"
                                            type="object"
                                            icon="fa-flag-checkered"
                                            class="btn btn-success btn-lg"
                                            style="font-weight: bold; font-size: 18px; padding: 10px 20px; float: right; border-radius: 8px;"
                                            attrs="{'invisible': [('is_acquired', '=', True)]}"
                                            help="Acquired skills are considered complete.  You cannot add goals, tasks, or update progress for them.">
                                    </button>
                                </div>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="help_view_form_popup" model="ir.ui.view">
            <field name="name">skill.help.popup</field>
            <field name="model">skill_development.help_popup</field>
            <field name="arch" type="xml">
                <form string="Skill Progress Help" create="false" edit="false">
                    <sheet>
                        <field name="step" invisible="1"/>
                        <group>
                            <group style="width: 66%; display: inline-block; vertical-align: top;">
                                <field name="message" widget="html" readonly="1" nolable="1"/>
                            </group>
                            <group style="width: 33%; display: inline-block; " col="1">
                                <field name="maximum_progress" invisible="1"/>
                                <field name="overall_progress"
                                       style="font-size: 30px; font-weight: bold"
                                       widget="gauge"
                                       options="{'max_field': 'maximum_progress'}"
                                       nolabel="1"
                                       attrs="{'invisible':[('step', '=', 'page2')]}"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="tips" widget="html" readonly="1" nolable="1"/>
                            </group>
                            <group attrs="{'invisible':[('step', '=', 'page1')]}">
                                <h1 t-att-style="'position: absolute; background-color: #2980b9; color: white; padding: 4px 10px; border-radius: 0 0 12px 0; font-size: 25px; font-weight: bold;'">
                                    <field name="title"/>
                                </h1>
                            </group>
                        </group>


                        <footer>
                            <button name="go_to_page1" string="Back" type="object"
                                    class="btn-secondary"
                                    attrs="{'invisible': [('step', '=', 'page1')]}"/>
                            <button name="go_to_page2" string="Next" type="object"
                                    class="btn-primary"
                                    attrs="{'invisible': [('step', '=', 'page2')]}"/>
                            <button string="Close" class="btn-secondary" special="cancel"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>