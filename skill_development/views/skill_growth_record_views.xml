<odoo>
    <data>
        <record id="skill_growth_view_tree" model="ir.ui.view">
            <field name="name">My Skill Growth</field>
            <field name="model">skill_development.initial_plan_record</field>
            <field name="arch" type="xml">
                <tree string="My Skill Growth" create="false">
                    <field name="sequence" widget="handle"/>
                    <field name="skill_name"/>
                    <field name="motivation"/>
                    <field name="endpoint" widget="remaining_days"/>
                    <button name="goals_button" type="object" string="Goals" icon="fa-arrow-right"/>
                </tree>
            </field>
        </record>

        <record id="skill_growth_view_form" model="ir.ui.view">
            <field name="name">My Skill Growth</field>
            <field name="model">skill_development.initial_plan_record</field>
            <field name="arch" type="xml">
                <form create="false">
                    <sheet>
                        <div class="oe_button_box" name="button_box" t-att-style="'position: relative;'">
                            <!-- Title as Badge -->
                            <h1 t-att-style="'position: absolute; background-color: #2980b9; color: white; padding: 4px 10px; border-radius: 0 0 12px 0; font-size: 25px; font-weight: bold;'">
                                <field name="title"/>
                            </h1>

                            <!-- Button Box with the Goal Button -->
                            <button name="goals_button"
                                    string="Goals"
                                    type="object"
                                    icon="fa-bullseye"
                                    class="oe_stat_button"
                                    t-att-style="'font-weight: bold; font-size: 14px;'">
                                <field name="goal_count" widget="statinfo"/>
                            </button>
                        </div>

                        <group col="1">
                            <group>
                                <group style="width: 66%; display: inline-block; vertical-align: top;">
                                    <field name="skill_name" required="1"/>
                                    <field name="motivation"/>
                                    <field name="endpoint"/>
                                    <field name="msg_2self"/>
                                </group>

                                <group style="width: 33%; display: inline-block; vertical-align: top;" col="1">
                                    <field name="maximum_progress" invisible="1"/>
                                    <field name="overall_progress"
                                           style="font-size: 30px; font-weight: bold"
                                           widget="gauge"
                                           options="{'max_field': 'maximum_progress'}"
                                           nolabel="1"/>
                                </group>
                            </group>
                        </group>


                        <group string="Progress Categories" col="3">
                            <!--                            <div class="row">-->
                            <group>
                                <field name="progress_knowledge" widget="percentpie"/>
                            </group>
                            <group>
                                <field name="progress_practice" widget="percentpie"/>
                            </group>
                            <group>
                                <field name="progress_contribute" widget="percentpie"/>
                            </group>
                            <!--                            </div>-->
                        </group>
                        <notebook>
                            <page string="Scribbles">
                                <group>
                                    <field name="scribble_note"
                                           type="html"
                                           class="o_field_text_block"
                                           style="height: 200px;"
                                           placeholder="Use this to quickly note skill ideas before you lose them..."
                                           colspan="2"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>