<odoo>
    <data>
                <record id="skill_record_view_kanban" model="ir.ui.view">
            <field name="name">skill_record.kanban</field>
            <field name="model">skill_development.skill_record</field>
            <field name="arch" type="xml">
                <kanban>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click"
                                 style="background-color: white; padding: 15px; border-radius: 10px; color: #002080;">
                                <!-- Skill Name - Big and Bold -->
                                <div class="o_kanban_record">
                                    <h2 style="font-size:20px; font-weight:bold; color:#24478f; text-align: left;">
                                        <field name="skill_name"/>
                                    </h2>
                                    <!-- To define the "Start Learning Button"-->
                                        <div class="kanban_buttons" style="text-align: right; margin-top: 10px;">
                                            <!-- (open_wizard_form) method is located in the model (skill_record) -->
                                            <!--to pass the skill name to the wizard, this context is needed-->
                                            <button type="object" name="action_open_initial_plan_wizard" class="btn btn-primary"
                                                    t-att-context="{'default_skill_id': record.id}"
                                                    string="Open Skill Plan Wizard">
<!--                                                    groups="skill_dev_ieeeanusb.group_skillDen_learner,skill_dev_ieeeanusb.group_skillDen_general_admin">-->
                                                Start Learning
                                            </button>
                                        </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="skill_record_view_form" model="ir.ui.view">
            <field name="name">skill_record.form</field>
            <field name="model">skill_development.skill_record</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <div class="oe_title" style="overflow: visible; white-space: nowrap;">
                            <h2 style="text-align:center">Skill Details</h2>
                        </div>
                    </header>
                    <sheet>
                        <!-- Add some padding to make the form more spacious -->
                        <div class="oe_form_container" style="padding: 15px;">
                            <!-- Organize the fields -->
                            <group string="General Information" colspan="2">
                                <field name="skill_name" placeholder="Enter skill name here"/>
                                <field name="description" widget="text" placeholder="Enter description..."/>
                                <field name="career_path_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                <field name="related_skill_ids" widget="many2many_tags"/>
                                <field name="pre_requisites"/>
                                <field name="is_transferable" widget="boolean_toggle"/>
<!--                                for user, restrictred by security group, add a t-if check raw value if field it true
 show text "This skill can be used trans" if not show text, this skills is specific to one role/ industry-->
                                <field name="prereq_skill_ids" widget="many2many_tags"/>
                            </group>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>