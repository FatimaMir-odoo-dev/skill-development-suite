        <record id="goal_task_view_kanban" model="ir.ui.view">
            <field name="name">My Tasks</field>
            <field name="model">skill_development.goal_task</field>
            <field name="arch" type="xml">
                <kanban default_group_by="stage_id">
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click"
                                 style="border: 1px solid #ddd; border-radius: 6px; padding: 12px; background: #fff;">
                                <!-- Title -->
                                <header>
                                    <div class="oe_title" style="overflow: visible; white-space: nowrap;">
                                        <h4 style="text-align: left; margin-bottom: 8px;">
                                            <field name="name"/>
                                        </h4>
                                    </div>
                                </header>
                                <field name="priority" widget="priority"/>
                                <field name="date_end" widget="remaining_days"/>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="goal_task_view_form" model="ir.ui.view">
            <field name="name">My Tasks</field>
            <field name="model">skill_development.goal_task</field>
            <field name="arch" type="xml">
                <form>
                    <div class="oe_title pe-0">
                        <h1 class="d-flex justify-content-between align-items-center">
                            <div class="d-flex w-100">
                                <field name="priority" widget="priority" class="me-3"/>
                                <field name="name" class="o_task_name text-truncate w-100 w-md-75 pe-2"
                                       placeholder="Task Title..."/>
                            </div>
                            <field name="kanban_state" widget="state_selection"/>
                        </h1>
                    </div>
                    <group>
                        <field name="goal_id" readonly="1"/>
                        <field name="date_end"/>
                    </group>
                    <group width="30%">
                        <field name="resource_url" widget="url"/>
                        <!--                        <button name="action_open_resource_form" type="object" string="Add Resource"/>-->
                    </group>
                    <notebook>
                        <page string="Task Description">
                            <field name="description" widget="html"/>
                        </page>
                        <page string="Additional Resources">
                            <field name="resource_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="resource_type" widget="badge"
                                           decoration-success="resource_type == 'image'"
                                           decoration-primary="resource_type == 'tool'"
                                           decoration-info="resource_type == 'link'"
                                           decoration-danger="resource_type == 'video'"
                                           decoration-warning="resource_type == 'document'"/>
                                    <field name="description"/>
                                    <field name="url" widget="url" string="External URLs"/>
                                    <!--                                    <field name="person_id"/>-->
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </form>
            </field>
        </record>

        <record id="goal_task_resource_view_form" model="ir.ui.view">
            <field name="name">My Tasks</field>
            <field name="model">skill_development.goal_task_resource</field>
            <field name="arch" type="xml">
                <form string="Resource">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="description"/>
                            <field name="resource_type"/>
                            <field name="video" filename="video_filename" widget="binary"
                                   attrs="{'invisible': [('resource_type', '!=', 'video')]}"/>
                            <field name="image" widget="image"
                                   attrs="{'invisible': [('resource_type', '!=', 'image')]}"/>
                            <field name="url" widget="url" attrs="{'invisible': [('resource_type', '!=', 'link')]}"/>
                            <field name="file" widget="pdf_viewer"
                                   attrs="{'invisible': [('resource_type', '!=', 'document')]}"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>