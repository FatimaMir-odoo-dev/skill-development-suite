<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="goal_project_view_kanban" model="ir.ui.view">
            <field name="name">My Goals</field>
            <field name="model">skill_development.goal_project</field>
            <field name="arch" type="xml">
                <kanban on_create="skill_development.open_create_goal_form_view">
                    <field name="goal_status" invisible="1"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click"
                                 style="border: 1px solid #ddd; border-radius: 6px; padding: 12px; background: #fff;">
                                <!-- Title -->
                                <header>
                                    <div class="oe_title" style="overflow: visible; white-space: nowrap;">
                                        <h4 style="text-align: left; margin-bottom: 8px;">
                                            <field name="goal_name"/>
                                        </h4>
                                    </div>
                                </header>

                                <!-- Skill Info -->
                                <h6 style="margin-top: 0; color: #555;">
                                    Skill:
                                    <span style="color: #ac00e6;">
                                        <field name="learner_plan_record_ids"/>
                                    </span>
                                </h6>

                                <!-- Tasks Button -->
                                <a name="action_view_tasks" type="object"
                                   style="text-decoration: none;">
                                    <div class="o_kanban_record_bottom"
                                         style="margin-top: 20px; padding: 10px; background-color: #f0f0f0; border-radius: 4px; text-align: right;"
                                         attrs="{'invisible':[('goal_status', '=', 'draft')]}">
                                        <span style="color: #333; font-weight: bold; display: inline-flex; align-items: center;">
                                            <i class="fa fa-tasks" style="margin-right: 5px;" aria-hidden="true"/>
                                            Tasks
                                        </span>
                                    </div>
                                </a>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="goal_project_view_form_popup" model="ir.ui.view">
            <field name="name">My Goals</field>
            <field name="model">skill_development.goal_project</field>
            <field name="arch" type="xml">
                <form>
                    <div style="display: flex; flex-direction: column; align-items: center;">
                        <!-- Skill Selection -->
                        <div style="display: flex; flex-direction: column; align-items: center; margin-bottom: 25px;">
                            <label for="learner_plan_record_ids"
                                   string="Choose the skill you want to develop with this goal."
                                   style="font-size: 14px; font-weight: 600; margin-bottom: 10px; color: #444444;"/>
                            <field name="learner_plan_record_ids"
                                   style="width: 50%; padding: 10px; border: 1px solid #dddddd; border-radius: 5px;"
                                   options="{'no_create': True}"/>
                            <label for="category"
                                   string="Which category?"
                                   widget="radio"
                                   style="font-size: 14px; font-weight: 600; margin-bottom: 10px; color: #444444;"/>
                            <field name="category"
                                   style="width: 50%; padding: 10px; border: 1px solid #dddddd; border-radius: 5px;"/>
                        </div>

                        <!-- SMART Goals Section -->
                        <div style="border: 1px solid #eeeeee; border-radius: 10px; padding: 25px; margin-bottom: 25px;">
                            <div style="display: flex; flex-direction: column; gap: 15px;">

                                <!-- Each SMART field -->
                                <div style="flex: 1;">
                                    <div style="font-size: 13px; font-weight: 500;">
                                        <span style="color: #71639c; font-weight: bold; font-size: 15px;">
                                            Specific:
                                        </span>
                                        <span style="color: #888888;">[What exactly do you want to
                                            achieve?]
                                        </span>
                                    </div>
                                    <field name="specific_goal"
                                           placeholder="e.g. learning to program with python"
                                           style="width: 100%; padding: 10px; border: 1px solid #dddddd; border-radius: 5px; margin-top: 5px;"/>
                                </div>

                                <!-- Repeat similar blocks for Measurable, Achievable, Relevant, Time-Bound -->

                                <div style="flex: 1;">
                                    <div style="font-size: 13px; font-weight: 500;">
                                        <span style="color: #71639c; font-weight: bold; font-size: 15px;">
                                            Measurable:
                                        </span>
                                        <span style="color: #888888;">[How do you know your progress is
                                            good?]
                                        </span>
                                    </div>
                                    <field name="measurable_goal"
                                           placeholder="e.g. Add two features per week."
                                           style="width: 100%; padding: 10px; border: 1px solid #dddddd; border-radius: 5px; margin-top: 5px;"/>
                                </div>

                                <!-- Achievable -->
                                <div style="flex: 1;">
                                    <div style="font-size: 13px; font-weight: 500;">
                                        <span style="color: #71639c; font-weight: bold; font-size: 15px;">
                                            Achievable:
                                        </span>
                                        <span style="color: #888888;">[What makes you sure you can do
                                            it?]
                                        </span>
                                    </div>
                                    <field name="achievable_goal"
                                           placeholder="e.g. I have a study group."
                                           style="width: 100%; padding: 10px; border: 1px solid #dddddd; border-radius: 5px; margin-top: 5px;"/>
                                </div>

                                <!-- Relevant -->
                                <div style="flex: 1;">
                                    <div style="font-size: 13px; font-weight: 500;">
                                        <span style="color: #71639c; font-weight: bold; font-size: 15px;">
                                            Relevant:
                                        </span>
                                        <span style="color: #888888;">[Why is it important to you?]
                                        </span>
                                    </div>
                                    <field name="relevant_goal"
                                           placeholder="e.g. Important for my portfolio."
                                           style="width: 100%; padding: 10px; border: 1px solid #dddddd; border-radius: 5px; margin-top: 5px;"/>
                                </div>

                                <!-- Time-Bound -->
                                <div style="flex: 1;">
                                    <div style="font-size: 13px; font-weight: 500;">
                                        <span style="color: #71639c; font-weight: bold; font-size: 15px;">
                                            Time-Bound:
                                        </span>
                                        <span style="color: #888888;">[What is your timeline?]</span>
                                    </div>
                                    <field name="timed_goal" placeholder="e.g. Finish by October."
                                           style="width: 100%; padding: 10px; border: 1px solid #dddddd; border-radius: 5px; margin-top: 5px;"/>
                                </div>

                            </div>
                        </div>

                        <h1 style="font-size: 18px; font-weight: 600; text-align: center;">Complete Goal
                            Statement
                        </h1>
                        <field name="goal_name"
                               placeholder="e.g. Learn Python and build an app."
                               style="width: 100%; padding: 15px; border: 1px solid #dddddd; border-radius: 5px; margin-bottom: 25px;"
                               required="True"
                        />
                    </div>
                    <footer>
                        <button name="action_create_goal_draft" string="Create Goal Draft" type="object"
                                class="btn btn-light"/>
                        <button name="action_finalize_goal" string="Finalize" type="object"
                                class="btn btn-primary"/>
                        <button string="Cancel"
                                class="btn-secondary"
                                special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="open_create_goal_form_view" model="ir.actions.act_window">
            <field name="name">Create a Project</field>
            <field name="res_model">skill_development.goal_project</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="goal_project_view_form_popup"/>
            <field name="target">new</field>
            <field name="context">{"default_allow_billable": 1}</field>
        </record>


        <record id="goal_project_view_form" model="ir.ui.view">
            <field name="name">My Goals</field>
            <field name="model">skill_development.goal_project</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="goal_status" widget="statusbar" statusbar_visible="draft,finalized,complete"/>
                    </header>
                    <button name="action_finalize_goal" string="Finalize" type="object"
                            class="btn btn-primary"
                            attrs="{'invisible':['|', ('goal_status', '=', 'finalized'), ('goal_status','=','complete')]}"/>
                    <field name="goal_name" attrs="{'readonly':[('goal_status', '=', 'finalized')]}"/>
                    <!--<sheet>-->
                    <notebook>

                        <page string="Expected Results">
                            <group>
                                <field name="result_ids"
                                       attrs="{'readonly': [('goal_status', '=', 'complete')]}">
                                    <tree editable="bottom">
                                        <field name="result"/>
                                        <field name="is_done"/>
                                    </tree>
                                </field>
                            </group>
                            <button name="action_complete_goal" string="Goal Complete" type="object"
                                    class="btn btn-success w-100"
                                    icon="fa-check-square-o"/>
                        </page>


                        <page string="SMART">
                            <div class="o_form_sheet border p-3">
                                <h3 class=" text-center mb-3" style="color: color: #71639c;">SMART
                                    Criteria
                                </h3>

                                <!-- Specific Goal -->
                                <div class="mb-3">
                                    <label class="fw-bold" for="specific_goal">Specific: [What exactly do
                                        you
                                        want to
                                        achieve?]
                                    </label>
                                    <div class="input-group">
                                        <field name="specific_goal" class="o_field_char form-control"
                                               id="specific_goal"
                                               attrs="{'readonly':[('goal_status', '=', 'finalized')]}"/>
                                    </div>
                                </div>

                                <!-- Measurable Goal -->
                                <div class="mb-3">
                                    <label class="fw-bold" for="measurable_goal" style="text-weight: bold">
                                        Measurable:
                                    </label>
                                    <!--                                <div class="input-group">-->
                                    <field name="measurable_goal" class="o_field_char form-control"
                                           id="measurable_goal"
                                           attrs="{'readonly':[('goal_status', '=', 'finalized')]}"/>
                                    <!--                                </div>-->
                                </div>

                                <!-- Achievable Goal -->
                                <div class="mb-3">
                                    <label class="fw-bold" for="achievable_goal">Achievable: [what makes you
                                        sure you can do
                                        it?]
                                    </label>
                                    <div class="input-group">
                                        <field name="achievable_goal" class="o_field_char form-control"
                                               id="achievable_goal"
                                               attrs="{'readonly':[('goal_status', '=', 'finalized')]}"/>
                                    </div>
                                </div>

                                <!-- Relevant Goal -->
                                <div class="mb-3">
                                    <label class="fw-bold" for="relevant_goal">Relevant: [Why is it
                                        important to
                                        you? (think
                                        of your motivation)]
                                    </label>
                                    <div class="input-group">
                                        <field name="relevant_goal" class="o_field_char form-control"
                                               id="relevant_goal"
                                               attrs="{'readonly':[('goal_status', '=', 'finalized')]}"/>
                                    </div>
                                </div>

                                <!-- Time-Bound Goal -->
                                <div class="mb-3">
                                    <label class="fw-bold" for="timed_goal">Time-Bound: [What is your
                                        timeline?]
                                    </label>
                                    <div class="input-group">
                                        <field name="timed_goal" class="o_field_char form-control"
                                               id="timed_goal"
                                               attrs="{'readonly':[('goal_status', '=', 'finalized')]}"/>
                                    </div>
                                </div>
                            </div>
                        </page>
                    </notebook>

                </form>
            </field>
        </record>

