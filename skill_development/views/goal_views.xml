<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="goal_project_view_kanban" model="ir.ui.view">
            <field name="name">My Goals</field>
            <field name="model">skill_development.goal_project</field>
            <field name="arch" type="xml">
                <kanban>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click"
                                 style="border: 1px solid #ddd; border-radius: 6px; padding: 12px; background: #fff;">
                                <!-- Title -->
                                <header>
                                    <div class="oe_title" style="overflow: visible; white-space: nowrap;">
                                        <h4 style="text-align: left; margin-bottom: 8px;">
                                            <field name="goal_name"/>
                                        </h4>
                                    </div>
                                </header>

                                <!-- Skill Info -->
                                <h6 style="margin-top: 0; color: #555;">
                                    Skill:
                                    <span style="color: #ac00e6;">
                                        <field name="learner_plan_record_ids"/>
                                    </span>
                                </h6>

                                <!-- Tasks Button -->
                                <a name="action_view_tasks" type="object"
                                   style="text-decoration: none;">
                                    <div class="o_kanban_record_bottom"
                                         style="margin-top: 20px; padding: 10px; background-color: #f0f0f0; border-radius: 4px; text-align: right;">
                                        <span style="color: #333; font-weight: bold; display: inline-flex; align-items: center;">
                                            <i class="fa fa-tasks" style="margin-right: 5px;" aria-hidden="true"/>
                                            Tasks
                                        </span>
                                    </div>
                                </a>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="goal_project_view_form" model="ir.ui.view">
            <field name="name">My Goals</field>
            <field name="model">skill_development.goal_project</field>
            <field name="arch" type="xml">
                <form>
                    <header>

                        <field name="goal_status" widget="statusbar" statusbar_visible="draft,finalized"/>
                    </header>

                    <div style="width: 50%; background-color: #f0f4ff; border-right: 1px solid #dddddd; box-sizing: border-box;">
                        <div style="max-width: 800px;">
                            <div style="display: flex; flex-direction: column; align-items: center; padding: 20px; background-color: #ffffff;">
                                <!-- Skill Selection -->
                                <div style="display: flex; flex-direction: column; align-items: center; margin-bottom: 25px;">
                                    <label for="learner_plan_record_ids"
                                           string="Choose the skill you want to develop with this goal."
                                           style="font-size: 14px; font-weight: 600; margin-bottom: 10px; color: #444444;"/>
                                    <field name="learner_plan_record_ids"
                                           style="width: 50%; padding: 10px; border: 1px solid #dddddd; border-radius: 5px;"
                                           options="{'no_create': True}"
                                           attrs="{'readonly': [('goal_status', '=', 'finalized')]}"/>
                                </div>
                                <!-- SMART Goals Section -->
                                <div style="border: 1px solid #eeeeee; border-radius: 10px; padding: 25px; margin-bottom: 25px;">
                                    <div style="display: flex; flex-direction: column; gap: 15px;">

                                        <!-- Specific Goal -->
                                        <div style="flex: 1;">
                                            <div style="font-size: 13px; font-weight: 500;">
                                                <span style="color: #71639c; font-weight: bold; font-size: 15px;">
                                                    Specific:
                                                </span>
                                                <span style="color: #888888;">[What exactly do you want to achieve?]
                                                </span>
                                            </div>
                                            <field name="specific_goal"
                                                   placeholder="e.g. learning to program with python"
                                                   style="width: 100%; padding: 10px; border: 1px solid #dddddd; border-radius: 5px; margin-top: 5px;"
                                                   attrs="{'readonly': [('goal_status', '=', 'finalized')]}"/>
                                        </div>

                                        <!-- Measurable Goal -->
                                        <div style="flex: 1;">
                                            <div style="font-size: 13px; font-weight: 500;">
                                                <span style="color: #71639c; font-weight: bold; font-size: 15px;">
                                                    Measurable:
                                                </span>
                                                <span style="color: #888888;">[How do you know if you're progress is
                                                    good?]
                                                </span>
                                            </div>
                                            <field name="measurable_goal"
                                                   placeholder="e.g. If I can add at least tow features to the application per week."
                                                   style="width: 100%; padding: 10px; border: 1px solid #dddddd; border-radius: 5px; margin-top: 5px;"
                                                   attrs="{'readonly': [('goal_status', '=', 'finalized')]}"/>
                                        </div>

                                        <!-- Achievable Goal -->
                                        <div style="flex: 1;">
                                            <div style="font-size: 13px; font-weight: 500;">
                                                <span style="color: #71639c; font-weight: bold; font-size: 15px;">
                                                    Achievable:
                                                </span>
                                                <span style="color: #888888;">[what makes you sure you can do it?]
                                                </span>
                                            </div>
                                            <field name="achievable_goal"
                                                   placeholder="e.g. I have enough time and a study group to motivate me."
                                                   style="width: 100%; padding: 10px; border: 1px solid #dddddd; border-radius: 5px; margin-top: 5px;"
                                                   attrs="{'readonly': [('goal_status', '=', 'finalized')]}"/>
                                        </div>

                                        <!-- Relevant Goal -->
                                        <div style="flex: 1;">
                                            <div style="font-size: 13px; font-weight: 500;">
                                                <span style="color: #71639c; font-weight: bold; font-size: 15px;">
                                                    Relevant:
                                                </span>
                                                <span style="color: #888888;">[Why is it important to you? (think of
                                                    your
                                                    motivation)]
                                                </span>
                                            </div>
                                            <field name="relevant_goal"
                                                   placeholder="e.g. I want to work in the field of programming, this is a good addition to my portfolio."
                                                   style="width: 100%; padding: 10px; border: 1px solid #dddddd; border-radius: 5px; margin-top: 5px;"
                                                   attrs="{'readonly': [('goal_status', '=', 'finalized')]}"/>
                                        </div>

                                        <!-- Timed Goal -->
                                        <div style="flex: 1;">
                                            <div style="font-size: 13px; font-weight: 500;">
                                                <span style="color: #71639c; font-weight: bold; font-size: 15px;">
                                                    Time-Bound:
                                                </span>
                                                <span style="color: #888888;">[What is your timeline?]</span>
                                            </div>
                                            <field name="timed_goal"
                                                   placeholder="e.g. I will start studying by July, 2nd. and finish the application by October, 2nd. "
                                                   style="width: 100%; padding: 10px; border: 1px solid #dddddd; border-radius: 5px; margin-top: 5px;"
                                                   attrs="{'readonly': [('goal_status', '=', 'finalized')]}"/>
                                        </div>

                                    </div>
                                </div>

                                <!--                        &lt;!&ndash; Divider &ndash;&gt;-->
                                <!--                        <div style="height: 1px; background-color: #dddddd; margin: 25px 0;"/>-->

                                <!-- Complete Goal Statement Header -->
                                <h1 style="font-size: 18px; font-weight: 600; text-align: center;">
                                    Complete Goal Statement
                                </h1>

                                <!-- Complete Goal Field -->
                                <field name="goal_name"
                                       placeholder="e.g. Learn to code in Python and build a simple web application within the next three months."
                                       style="width: 100%; padding: 15px; border: 1px solid #dddddd; border-radius: 5px; margin-bottom: 25px;"
                                       required="True"
                                       attrs="{'readonly': [('goal_status', '=', 'finalized')]}"/>
                                <button name="action_finalize_goal"
                                        string="Finalize"
                                        type="object"
                                        class="btn btn-success w-100"
                                        attrs="{'invisible': [('goal_status', '=', 'finalized')]}"/>
                            </div>
                        </div>
                    </div>
                </form>
            </field>
        </record>
    </data>
</odoo>