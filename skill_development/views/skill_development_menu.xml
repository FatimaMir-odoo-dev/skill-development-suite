<odoo>
    <data>
<!--        <menuitem id="menu_skill_development"-->
<!--                  name="Skills"/>-->
        <!--                  web_icon="skill_development,static/description/icon1.png"/>-->

        <record id="skill_development.skill_record_action" model="ir.actions.act_window">
            <field name="name">Skills</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">skill_development.skill_record</field>
            <field name="view_mode">kanban,form</field>
            <!--            <field name="view_id" ref="skill_record_view_kanban"/>-->
        </record>
        <menuitem id="menu_skill_record"
                  name="Skill Catalog"
                  action="skill_development.skill_record_action"
                  sequence="10"
                  web_icon="skill_development,static/description/icon1.png"
                  groups="skill_development_group_learner"/>

        <record id="skill_development.initial_plan_record_action" model="ir.actions.act_window">
            <field name="name">My Skill Growth</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">skill_development.initial_plan_record</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="skill_growth_view_tree"/>
            <!--            <field name="view_id" ref="skill_record_view_kanban"/>-->
        </record>
        <menuitem id="menu_skill_growth_record"
                  name="Skill Growth"
                  action="skill_development.initial_plan_record_action"
                  sequence="20"/>
        <!--                  web_icon="skill_development,static/description/icon1.png"/>-->
        <!--                  web_icon="skill_development,static/description/icon1.png"/>-->

        <!--        <record id="action_goal_project_popup_form" model="ir.actions.act_window">-->
        <!--            <field name="name">New Goal Popup</field>-->
        <!--            <field name="res_model">skill_development.goal_project</field>-->
        <!--            <field name="view_mode">form</field>-->
        <!--            <field name="target">new</field> &lt;!&ndash; Modal popup &ndash;&gt;-->
        <!--        </record>-->
        <record id="action_priority_task" model="ir.actions.act_window">
            <field name="name">Priority Tasks</field>
            <field name="res_model">skill_development.task</field>
            <field name="view_mode">kanban,form</field>
            <field name="domain">[('priority', '=', 1)]</field>
            <field name="context">{'group_by': 'goal_id',
                'group_create': False,
                'create': False}</field>
        </record>

        <menuitem id="menu_priority_task"
                  name="Priority Tasks"
                  parent="menu_skill_growth_record"
                  action="action_priority_task"
                  sequence="5"/>

        <record id="action_goal" model="ir.actions.act_window">
            <field name="name">My Goals</field>
            <field name="res_model">skill_development.goal</field>
            <field name="view_mode">kanban,form</field>
            <field name="context">{'create': False}</field>
        </record>

        <menuitem id="menu_goal"
                  name="My Goals"
                  parent="menu_skill_growth_record"
                  action="action_goal"
                  sequence="6"/>


        <record id="skill_development.lesson_bank_action" model="ir.actions.act_window">
            <field name="name">Lesson Bank</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">skill_development.lesson_bank</field>
            <field name="view_mode">tree,form</field>
<!--            <field name="context">{'form_view_ref': 'skill_development.goal_lesson_bank_view_form_popup'}</field>-->
            <!--            <field name="view_id" ref="skill_growth_view_tree"/>-->
            <!--            <field name="view_id" ref="skill_record_view_kanban"/>-->
        </record>
        <menuitem id="menu_lesson_bank"
                  name="Lesson Bank"
                  action="skill_development.lesson_bank_action"
                  parent="menu_skill_growth_record"
                  sequence="10"/>

        <record id="action_resource_form" model="ir.actions.act_window">
            <field name="name">Resources</field>
            <field name="res_model">skill_development.task.resource</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>