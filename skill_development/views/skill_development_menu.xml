        <!--                  web_icon="skill_development,static/description/icon1.png"/>-->

        <record id="skills_action" model="ir.actions.act_window">
            <field name="name">Skills</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">skill_development.skill</field>
            <field name="view_mode">kanban,form</field>
            <!--            <field name="view_id" ref="skill_record_view_kanban"/>-->
        </record>
        <menuitem id="skill_menu"
                  name="Skill Catalog"
                  action="skills_action"
                  sequence="10"
                  web_icon="skill_development,static/description/icon1.png"
                  groups="skill_development_group_learner"/>



        <record id="growth_tracker_action" model="ir.actions.act_window">
            <field name="name">My Skill Growth</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">skill_development.growth_tracker</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="growth_tracker_view_tree"/>
            <!--            <field name="view_id" ref="skill_record_view_kanban"/>-->
        </record>

        <menuitem id="growth_tracker_menu"
                  name="Skill Growth"
                  action="growth_tracker_action"
                  sequence="20"/>
        <!--                  web_icon="skill_development,static/description/icon1.png"/>-->
        <!--                  web_icon="skill_development,static/description/icon1.png"/>-->

        <!--        <record id="action_goal_project_popup_form" model="ir.actions.act_window">-->
        <!--            <field name="name">New Goal Popup</field>-->
        <!--            <field name="res_model">skill_development.goal_project</field>-->
        <!--            <field name="view_mode">form</field>-->
        <!--            <field name="target">new</field> &lt;!&ndash; Modal popup &ndash;&gt;-->
        <!--        </record>-->
        <record id="priority_tasks_action" model="ir.actions.act_window">
            <field name="name">Priority Tasks</field>
            <field name="res_model">skill_development.task</field>
            <field name="view_mode">kanban,form</field>
            <field name="domain">[('priority', '=', 1)]</field>
            <field name="context">{'group_by': 'goal_id',
                'group_create': False,
                'create': False}</field>
        </record>

        <menuitem id="growth_tracker_menu_priority_tasks"
                  name="Priority Tasks"
                  parent="growth_tracker_menu"
                  action="priority_tasks_action"
                  sequence="5"/>

        <record id="goals_action" model="ir.actions.act_window">
            <field name="name">My Goals</field>
            <field name="res_model">skill_development.goal</field>
            <field name="view_mode">kanban,form</field>
            <field name="context">{'create': False}</field>
        </record>

        <menuitem id="growth_tracker_menu_goals"
                  name="My Goals"
                  parent="growth_tracker_menu"
                  action="goals_action"
                  sequence="6"/>


        <record id="lesson_bank_action" model="ir.actions.act_window">
            <field name="name">Lesson Bank</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">skill_development.lesson_bank</field>
            <field name="view_mode">tree,form</field>
<!--            <field name="context">{'form_view_ref': 'skill_development.goal_lesson_bank_view_form_popup'}</field>-->
            <!--            <field name="view_id" ref="skill_growth_view_tree"/>-->
            <!--            <field name="view_id" ref="skill_record_view_kanban"/>-->
        </record>
        <menuitem id="growth_tracker_menu_lesson_bank"
                  name="Lesson Bank"
                  action="lesson_bank_action"
                  parent="growth_tracker_menu"
                  sequence="10"/>

        <record id="resources_action" model="ir.actions.act_window">
            <field name="name">Resources</field>
            <field name="res_model">skill_development.task_resource</field>
            <field name="view_mode">tree,form</field>
        </record>

</odoo>
