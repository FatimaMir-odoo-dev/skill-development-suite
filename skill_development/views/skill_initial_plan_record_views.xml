<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="learner_profile_view_form" model="ir.ui.view">
            <field name="name">learner_profile.form</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="hr.res_users_view_form_profile"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook/page[1]" position="before">
                    <page string="My Skill List">
                        <h2 class="o_view_header">My Skills</h2>
                        <div class="o_list_view">
                            <field name="plan_skill_ids">
                                <tree>
                                    <field name="skill_name"/>
                                    <field name="motivation"/>
                                    <field name="endpoint"/>
                                    <field name="msg_2self"/>
                                </tree>
                            </field>
                        </div>
                    </page>
                </xpath>

<!--                <xpath expr="//field[@name='coach_id']" position="replace">-->
<!--                </xpath>-->

<!--                <xpath expr="//page[@name='public']//field[@name='address_id']" position="attributes">-->
<!--                    <attribute name="attrs">{'invisible': True}</attribute>-->
<!--                </xpath>-->
<!--                <xpath expr="//page[@name='public']//field[@name='address_id']" position="after">-->
<!--                    <field name="position"/>-->
<!--                </xpath>-->
            </field>
        </record>
    </data>
</odoo>